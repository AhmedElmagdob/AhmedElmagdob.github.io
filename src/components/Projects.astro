---
import { projects } from '../data/portfolio';
import StoreLink from './StoreLink.astro';

const featured = projects.filter((p) => p.featured);
const regular = projects.filter((p) => !p.featured);
---

<section id="projects" class="section-alt py-20 sm:py-28">
  <div class="section-container">
    <div class="reveal mb-16 text-center">
      <h2 class="section-heading reveal-heading">Projects</h2>
      <p class="section-subheading mx-auto">
        Published apps serving thousands of users across iOS and Android.
      </p>
    </div>

    {
      featured.map((project) => (
        <article class="project-card project-card--featured reveal mb-8 lg:flex">
          <div class="project-card-media">
            <img
              src={project.image}
              alt={`${project.name} app icon`}
              class="project-card-icon h-28 w-28 sm:h-36 sm:w-36"
              loading="lazy"
              width="144"
              height="144"
            />
            <span class="featured-badge">Featured</span>
          </div>
          <div class="project-card-content">
            <h3 class="text-xl font-bold text-heading sm:text-2xl">{project.name}</h3>
            <p class="mt-2.5 text-sm leading-relaxed text-body sm:mt-3 sm:text-base">
              {project.description}
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              {project.tools.map((tool) => (
                <span class="chip">{tool}</span>
              ))}
            </div>
            <div class="project-card-actions">
              {project.links.length > 0 ? (
                project.links.map((link) => <StoreLink link={link} variant="button" />)
              ) : (
                <span class="chip">Available on Google Play & App Store</span>
              )}
            </div>
          </div>
        </article>
      ))
    }

    <div class="grid gap-5 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
      {
        regular.map((project, index) => (
          <article class="project-card reveal flex flex-col" data-reveal-delay={index * 80}>
            <div class="project-card-media">
              <img
                src={project.image}
                alt={`${project.name} app icon`}
                class="project-card-icon h-20 w-20 sm:h-24 sm:w-24"
                loading="lazy"
                width="96"
                height="96"
              />
            </div>
            <div class="project-card-content">
              <h3 class="text-base font-semibold text-heading">{project.name}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-body line-clamp-3">
                {project.description}
              </p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {project.tools.slice(0, 3).map((tool) => (
                  <span class="chip text-[11px]">{tool}</span>
                ))}
                {project.tools.length > 3 && (
                  <span class="chip text-[11px]">+{project.tools.length - 3}</span>
                )}
              </div>
              <div class="project-card-actions">
                {project.links.length > 0 ? (
                  project.links.map((link) => <StoreLink link={link} variant="inline" />)
                ) : (
                  <span class="text-xs font-medium text-muted">Google Play & App Store</span>
                )}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('#projects .reveal-heading').forEach((el) => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    observer.observe(el);
  });
</script>
