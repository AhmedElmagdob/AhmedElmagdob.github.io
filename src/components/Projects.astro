---
import { projects } from '../data/portfolio';
import StoreLink from './StoreLink.astro';

const featured = projects.filter((p) => p.featured);
const regular = projects.filter((p) => !p.featured);
---

<section id="projects" class="section-alt py-20 sm:py-28">
  <div class="section-container">
    <div class="reveal mb-16 text-center">
      <h2 class="section-heading reveal-heading">Projects</h2>
      <p class="section-subheading mx-auto">
        Published apps serving thousands of users across iOS and Android.
      </p>
    </div>

    {
      featured.map((project) => (
        <article class="project-card reveal mb-8 lg:flex">
          <div class="relative flex shrink-0 items-center justify-center p-8 lg:w-72" style="background: var(--color-accent-muted)">
            <img
              src={project.image}
              alt={`${project.name} app icon`}
              class="h-32 w-32 rounded-3xl object-cover shadow-lg ring-1 ring-[var(--color-border)] transition-transform duration-300 hover:scale-105 sm:h-40 sm:w-40"
              loading="lazy"
              width="160"
              height="160"
            />
            <span class="featured-badge">Featured</span>
          </div>
          <div class="flex flex-1 flex-col justify-center p-6 sm:p-8">
            <h3 class="text-2xl font-bold text-heading">{project.name}</h3>
            <p class="mt-3 leading-relaxed text-body">{project.description}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {project.tools.map((tool) => (
                <span class="chip">{tool}</span>
              ))}
            </div>
            <div class="mt-6 flex flex-wrap gap-3">
              {project.links.length > 0 ? (
                project.links.map((link) => <StoreLink link={link} variant="button" />)
              ) : (
                <span class="chip">Available on Google Play & App Store</span>
              )}
            </div>
          </div>
        </article>
      ))
    }

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        regular.map((project, index) => (
          <article class="project-card reveal flex flex-col" data-reveal-delay={index * 80}>
            <div class="flex items-center justify-center p-6" style="background: var(--color-accent-muted)">
              <img
                src={project.image}
                alt={`${project.name} app icon`}
                class="h-24 w-24 rounded-2xl object-cover shadow-md ring-1 ring-[var(--color-border)] transition-transform duration-300 hover:scale-105"
                loading="lazy"
                width="96"
                height="96"
              />
            </div>
            <div class="flex flex-1 flex-col p-5">
              <h3 class="text-lg font-semibold text-heading">{project.name}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-body">
                {project.description}
              </p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {project.tools.slice(0, 4).map((tool) => (
                  <span class="chip text-[11px]">{tool}</span>
                ))}
                {project.tools.length > 4 && (
                  <span class="chip text-[11px]">+{project.tools.length - 4}</span>
                )}
              </div>
              <div class="mt-4 flex flex-wrap gap-2 border-t pt-4" style="border-color: var(--color-border)">
                {project.links.length > 0 ? (
                  project.links.map((link) => <StoreLink link={link} variant="inline" />)
                ) : (
                  <span class="text-xs font-medium text-muted">Google Play & App Store</span>
                )}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('#projects .reveal-heading').forEach((el) => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    observer.observe(el);
  });
</script>
