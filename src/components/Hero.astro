---
import { site, stats } from '../data/portfolio';
---

<section id="lead" class="hero-gradient bg-grid relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-4 pt-20">
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true" data-hero-orbs>
    <div
      data-hero-orb
      data-hero-orb-tone="cyan"
      class="hero-orb animate-float absolute left-0 top-0 h-80 w-80 rounded-full blur-3xl sm:h-96 sm:w-96"
    ></div>
    <div
      data-hero-orb
      data-hero-orb-tone="purple"
      class="hero-orb animate-float absolute left-0 top-0 h-80 w-80 rounded-full blur-3xl sm:h-96 sm:w-96"
    ></div>
    <div
      data-hero-orb
      data-hero-orb-tone="pink"
      class="hero-orb animate-float absolute left-0 top-0 h-72 w-72 rounded-full blur-3xl sm:h-80 sm:w-80"
    ></div>
  </div>

  <div class="relative z-10 mx-auto max-w-4xl text-center">
    <p class="reveal mb-4 text-sm font-semibold uppercase tracking-widest text-accent">
      Senior Flutter Developer
    </p>
    <h1 class="reveal text-4xl font-extrabold tracking-tight text-heading sm:text-5xl md:text-6xl lg:text-7xl dark:text-white dark:neon-text">
      {site.name}
    </h1>
    <p class="reveal mt-4 text-lg text-muted sm:text-xl md:text-2xl dark:text-slate-300">
      {site.title}
    </p>

    <div class="reveal mt-10 flex flex-wrap items-center justify-center gap-4 sm:gap-6">
      {
        stats.map((stat, index) => (
          <div class="stat-card" data-reveal-delay={index * 100}>
            <div class="text-2xl font-bold text-heading sm:text-3xl dark:text-white">{stat.value}</div>
            <div class="mt-1 text-xs font-medium uppercase tracking-wide text-muted sm:text-sm">
              {stat.label}
            </div>
          </div>
        ))
      }
    </div>

    <div class="reveal mt-12 flex flex-wrap items-center justify-center gap-4">
      <a
        href={site.resumeUrl}
        download="Ahmed_Abdelrahim_Flutter_Developer.pdf"
        class="btn-primary"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Download Resume
      </a>
      <a href="#contact" class="btn-secondary">
        Get in Touch
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>

  <a
    href="#about"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 text-muted transition-colors duration-300 hover:text-accent motion-safe:animate-bounce"
    aria-label="Scroll to about section"
  >
    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </a>
</section>

<script>
  document.querySelectorAll('#lead .reveal').forEach((el, i) => {
    setTimeout(() => el.classList.add('visible'), 100 + i * 150);
  });
</script>

<script src="../scripts/hero-orbs.ts"></script>

<style>
  .hero-orb {
    will-change: transform, opacity;
    transform-origin: center center;
  }

  [data-hero-orb-tone='cyan'] {
    background: radial-gradient(circle, rgba(56, 189, 248, 0.35) 0%, rgba(56, 189, 248, 0.08) 45%, transparent 70%);
  }

  [data-hero-orb-tone='purple'] {
    background: radial-gradient(circle, rgba(99, 102, 241, 0.32) 0%, rgba(139, 92, 246, 0.1) 45%, transparent 70%);
  }

  :global(.dark) [data-hero-orb-tone='cyan'] {
    background: radial-gradient(circle, rgba(0, 240, 255, 0.45) 0%, rgba(0, 240, 255, 0.12) 40%, transparent 68%);
  }

  :global(.dark) [data-hero-orb-tone='purple'] {
    background: radial-gradient(circle, rgba(191, 0, 255, 0.4) 0%, rgba(191, 0, 255, 0.1) 42%, transparent 68%);
  }

  [data-hero-orb-tone='pink'] {
    background: radial-gradient(circle, rgba(244, 114, 182, 0.34) 0%, rgba(236, 72, 153, 0.1) 45%, transparent 70%);
  }

  :global(.dark) [data-hero-orb-tone='pink'] {
    background: radial-gradient(circle, rgba(255, 0, 128, 0.42) 0%, rgba(255, 110, 199, 0.12) 42%, transparent 68%);
  }
</style>
